def get_sanad_dir() -> Path:
    if os.name == "nt":
        base = Path(os.environ.get("APPDATA", Path.home()))
    else:
        base = Path.home() / ".local" / "share"
    d = base / "Sanad"
    d.mkdir(parents=True, exist_ok=True)
    return d


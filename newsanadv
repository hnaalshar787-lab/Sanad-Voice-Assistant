_speak_lock  = threading.Lock()

def speak(text: str, wait: bool = False):
    """ينطق النص بالعربية — يدعم الانتظار (wait=True) للتسلسل الصوتي"""
    def _run():
        with _speak_lock:
            _speak_gtts(text)

    t = threading.Thread(target=_run, daemon=True)
    t.start()
    if wait:
        t.join()


def _speak_gtts(text: str):
    """تشغيل الصوت عبر gTTS — يضمن اكتمال الجملة"""
    if not GTTS_OK:
        _speak_fallback(text)
        return
    try:
        tmp = tempfile.NamedTemporaryFile(suffix=".mp3", delete=False)
        tmp.close()
        tts = gTTS(text=text, lang='ar', slow=False)
        tts.save(tmp.name)

        if os.name == "nt":
            import ctypes
            alias = "sanad_snd"
            ctypes.windll.winmm.mciSendStringW(
                f'open "{tmp.name}" type mpegvideo alias {alias}', None, 0, None)
            ctypes.windll.winmm.mciSendStringW(
                f'play {alias} wait', None, 0, None)
            ctypes.windll.winmm.mciSendStringW(
                f'close {alias}', None, 0, None)
        else:
            if os.system(f'which mpg123 > /dev/null 2>&1') == 0:
                os.system(f'mpg123 -q "{tmp.name}"')
            elif os.system(f'which afplay > /dev/null 2>&1') == 0:
                os.system(f'afplay "{tmp.name}"')
            else:
                try:
                    import pygame
                    pygame.mixer.init()
                    pygame.mixer.music.load(tmp.name)
                    pygame.mixer.music.play()
                    while pygame.mixer.music.get_busy():
                        time.sleep(0.05)
                except Exception:
                    pass
    except Exception as e:
        print(f"[gTTS Error] {e}")
        _speak_fallback(text)
    finally:
        try:
            os.unlink(tmp.name)
        except Exception:
            pass


def _speak_fallback(text: str):
    """احتياط: pyttsx3 عند عدم توفر gTTS أو الإنترنت"""
    try:
        import pyttsx3
        eng = pyttsx3.init()
        eng.setProperty('rate', 130)
        eng.setProperty('volume', 1.0)
        for v in eng.getProperty('voices'):
            if 'arab' in v.id.lower() or 'ar' in v.id.lower():
                eng.setProperty('voice', v.id)
                break
        eng.say(text)
        eng.runAndWait()
    except Exception as e:
        print(f"[Fallback TTS Error] {e}")



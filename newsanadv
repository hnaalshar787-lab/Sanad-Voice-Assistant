                     text_color=C["gold"]).pack(side="right", padx=20)

        SeparatorLine(self).pack(fill="x")

        ctk.CTkFrame(self, height=18, fg_color="transparent").pack()
        GoldenRingsCanvas(self, size=130).pack()
        ctk.CTkFrame(self, height=8, fg_color="transparent").pack()

        ctk.CTkLabel(self, text="مرحباً بعودتك",
                     font=("Georgia", 22, "bold"),
                     text_color=C["white"]).pack()
        ctk.CTkLabel(self, text="انطق كلمتك السرية للدخول",
                     font=("Helvetica", 14),
                     text_color=C["white_70"]).pack(pady=(4, 18))

        # بطاقة شرح التحقق المزدوج
        info_card = ctk.CTkFrame(self, fg_color=C["card"], corner_radius=14,
                                  border_color=C["card_border"], border_width=1)
        info_card.pack(fill="x", padx=30, pady=(0, 12))
        ctk.CTkLabel(info_card,
                     text="🔐  التحقق المزدوج: كلمة المرور + بصمة الصوت",
                     font=("Helvetica", 12),
                     text_color=C["white_40"]).pack(padx=16, pady=10)

        self.wave = VoiceWaveCanvas(self, height=70)
        self.wave.pack(fill="x", padx=30, pady=8)

        self.status = StatusBadge(self, text="اضغط الزر وانطق كلمتك السرية")
        self.status.pack(padx=30, fill="x", pady=12)

        self.btn = GoldButton(self, text="🔊  ابدأ التحقق الصوتي",
                              command=self._start_voice)
        self.btn.pack(fill="x", padx=30, pady=(8, 14))

    # ── دخول بالصوت ─────────────────────────────────────
    def _start_voice(self):
        self.btn.configure(state="disabled")
        speak("قل كلمتك السرية الآن.")
        threading.Thread(target=self._logic_voice, daemon=True).start()

    def _logic_voice(self):
        self.status.update("🎤 تحدث الآن...", C["warning"])
        self.wave.start()
        rec = sd.rec(int(self.DUR * self.FS), samplerate=self.FS, channels=1)
        sd.wait()
        self.wave.stop()

        word   = transcribe_audio(rec, self.FS)
        fp_now = extract_fingerprint(rec, self.FS)
        uid, w = self._match_user(word, fp_now, SecurityLayer.LOGIN_THRESHOLD)
        self._handle_result(uid, w)

    def _match_user(self, word, fp_now, threshold):
        """التحقق المزدوج: كلمة المرور + البصمة الصوتية"""
        for uid in SecurityLayer.list_users():
            h = SecurityLayer.get_word_hash(uid)
            if SecurityLayer.verify_spoken_word(word, h):
                stored = SecurityLayer.load_fingerprint(uid, word)
                if stored is not None and voice_similarity(fp_now, stored) > threshold:
                    return uid, word
        return None, None

    def _handle_result(self, uid, word):
        if uid:
            speak("مرحباً. تم التحقق من هويتك بنجاح. جارٍ فتح حسابك.")
            self.status.update("✅ تم التحقق بنجاح!", C["success"])
            self.after(1200, lambda: self.on_success(uid, word))
        else:
            speak("عذراً، لم يتطابق الصوت أو الكلمة. حاول مرة أخرى.")
            self.status.update("❌ فشل التحقق. حاول مجدداً.", C["danger"])
            self.after(0, lambda: self.btn.configure(state="normal"))



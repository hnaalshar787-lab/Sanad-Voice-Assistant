class GoldenRingsCanvas(ctk.CTkCanvas):
    """حلقات ذهبية متحركة — شعار سَنَد"""
    def __init__(self, master, size=180, **kwargs):
        super().__init__(master, width=size, height=size,
                         bg=C["bg"], highlightthickness=0, **kwargs)
        self.size  = size
        self.phase = 0.0
        self.pulse = 0.0
        self._animate()

    def _animate(self):
        self.delete("all")
        cx = self.size / 2
        self.phase += 0.04
        self.pulse  = 0.5 + 0.5 * math.sin(self.phase * 2)

        for r, rc in zip([28, 44, 60], [C["gold"], C["gold_dark"], C["white_40"]]):
            self.create_oval(cx-r, cx-r, cx+r, cx+r, outline=rc, width=1)

        r_p = 68 + 6 * self.pulse
        self.create_oval(cx-r_p, cx-r_p, cx+r_p, cx+r_p,
                         outline=C["gold"], width=2 + self.pulse)

        for i, (rx, ry) in enumerate([(10,7),(8,10),(6,13),(4,10),(2,7)]):
            off = i * 3
            self.create_arc(cx-rx+off, cx-ry, cx+rx+off, cx+ry,
                            start=200, extent=140,
                            outline=C["gold_lt"], width=1, style="arc")

        r_d = 3 + 2 * self.pulse
        self.create_oval(cx-r_d, cx-r_d, cx+r_d, cx+r_d,
                         fill=C["gold"], outline="")
        self.after(40, self._animate)


class VoiceWaveCanvas(ctk.CTkCanvas):
    """موجة صوتية متحركة تُظهر نشاط الميكروفون"""
    def __init__(self, master, height=70, **kwargs):
        super().__init__(master, height=height, bg=C["card"],
                         highlightthickness=0, **kwargs)
        self.active    = False
        self.phase     = 0.0
        self.amplitude = 0.0
        self._animate()

    def _animate(self):
        self.delete("wave")
        w = self.winfo_width() or 300
        h = self.winfo_height() or 70

        if self.active:
            self.amplitude = min(self.amplitude + 0.15, 1.0)
        else:
            self.amplitude = max(self.amplitude - 0.05, 0.0)

        amp = self.amplitude * (h * 0.35)
        if amp > 0.5:
            pts = []
            for x in range(0, w + 5, 3):
                y = h/2 + amp * math.sin(x * 0.06 + self.phase)
                pts.extend([x, y])
            if len(pts) > 4:
                self.create_line(*pts, fill=C["gold"], width=2.5,
                                 smooth=True, tags="wave")
            pts2 = []
            for x in range(0, w + 5, 3):
                y = h/2 + (amp*0.4) * math.sin(x * 0.1 + self.phase * 1.3 + 1)
                pts2.extend([x, y])
            if len(pts2) > 4:
                self.create_line(*pts2, fill=C["gold_dark"], width=1.5,
                                 smooth=True, tags="wave")
        else:
            self.create_line(0, h/2, w, h/2, fill=C["white_40"], width=1, tags="wave")

        self.phase += 0.18
        self.after(30, self._animate)

    def start(self): self.active = True
    def stop(self):  self.active = False


class StepsIndicator(ctk.CTkFrame):
    """مؤشر الخطوات — خطوتان فقط: الكلمة السرية والحفظ"""
    LABELS = ["الكلمة السرية", "الحفظ"]

    def __init__(self, master, **kwargs):
        super().__init__(master, fg_color="transparent", **kwargs)
        self.dots, self.labels = [], []
        for lbl in self.LABELS:
            col = ctk.CTkFrame(self, fg_color="transparent")
            col.pack(side="left", padx=14)
            d = ctk.CTkFrame(col, width=24, height=24,
                             corner_radius=12, fg_color=C["step_wait"])
            d.pack()
            l = ctk.CTkLabel(col, text=lbl, font=("Helvetica", 10),
                             text_color=C["white_40"])
            l.pack(pady=(4, 0))
            self.dots.append(d)
            self.labels.append(l)

    def set_step(self, step: int):
        for i, (d, l) in enumerate(zip(self.dots, self.labels)):
            if i < step:
                d.configure(fg_color=C["step_done"])
                l.configure(text_color=C["success"])
            elif i == step:
                d.configure(fg_color=C["step_act"])
                l.configure(text_color=C["gold"])
            else:
                d.configure(fg_color=C["step_wait"])
                l.configure(text_color=C["white_40"])



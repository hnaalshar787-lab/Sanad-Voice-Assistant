def preprocess_audio(recording: np.ndarray, fs: int = 16000) -> np.ndarray:
    y = recording.flatten().astype(np.float32)
    y_trimmed, _ = librosa.effects.trim(y, top_db=20)
    if np.max(np.abs(y_trimmed)) > 0:
        y_trimmed = y_trimmed / np.max(np.abs(y_trimmed))
    y_pre = np.append(y_trimmed[0], y_trimmed[1:] - 0.97 * y_trimmed[:-1])
    return y_pre


def extract_fingerprint(recording: np.ndarray, fs: int = 16000) -> np.ndarray:
    y = preprocess_audio(recording, fs)
    mfccs    = librosa.feature.mfcc(y=y, sr=fs, n_mfcc=40)
    delta1   = librosa.feature.delta(mfccs)
    delta2   = librosa.feature.delta(mfccs, order=2)
    chroma   = librosa.feature.chroma_stft(y=y, sr=fs, n_chroma=12)
    contrast = librosa.feature.spectral_contrast(y=y, sr=fs, n_bands=6)
    zcr      = librosa.feature.zero_crossing_rate(y)
    rms      = librosa.feature.rms(y=y)
    mel      = librosa.feature.melspectrogram(y=y, sr=fs, n_mels=40)
    mel_db   = librosa.power_to_db(mel, ref=np.max)
    features = np.concatenate([
        np.mean(mfccs, axis=1),    np.std(mfccs, axis=1),
        np.mean(delta1, axis=1),   np.std(delta1, axis=1),
        np.mean(delta2, axis=1),
        np.mean(chroma, axis=1),   np.std(chroma, axis=1),
        np.mean(contrast, axis=1),
        [np.mean(zcr), np.std(zcr)],
        [np.mean(rms), np.std(rms)],
        np.mean(mel_db, axis=1),
    ])
    return features


def voice_similarity(fp1: np.ndarray, fp2: np.ndarray) -> float:
    if fp1 is None or fp2 is None:
        return 0.0
    min_len = min(len(fp1), len(fp2))
    fp1, fp2 = fp1[:min_len], fp2[:min_len]
    n1, n2 = np.linalg.norm(fp1), np.linalg.norm(fp2)
    if n1 == 0 or n2 == 0:
        return 0.0
    cosine = float(np.dot(fp1, fp2) / (n1 * n2))
    dist = np.linalg.norm(fp1 - fp2)
    max_dist = n1 + n2
    euclidean_sim = 1.0 - (dist / max_dist) if max_dist > 0 else 0.0
    return 0.6 * cosine + 0.4 * euclidean_sim


def aggregate_fingerprints(fps: list) -> np.ndarray:
    if not fps:
        return None
    if len(fps) == 1:
        return fps[0]
    min_len = min(len(f) for f in fps)
    fps_t = [f[:min_len] for f in fps]
    n = len(fps_t)
    weights = np.ones(n)
    for i in range(n):
        for j in range(n):
            if i != j:
                weights[i] += voice_similarity(fps_t[i], fps_t[j])
    weights /= weights.sum()
    result = np.zeros(min_len)
    for fp, w in zip(fps_t, weights):
        result += w * fp
    return result


def transcribe_audio(recording: np.ndarray, fs: int = 16000) -> str:
    if not SR_OK:
        fp = extract_fingerprint(recording, fs)
        return "voice_" + hashlib.md5(fp.tobytes()).hexdigest()[:8]
    try:
        import io, wave as wavemod
        recognizer = sr.Recognizer()
        recognizer.energy_threshold = 300
        recognizer.dynamic_energy_threshold = True
        recognizer.pause_threshold = 0.8
        y = (recording.flatten() * 32767).astype(np.int16)
        buf = io.BytesIO()
        with wavemod.open(buf, 'wb') as wf:
            wf.setnchannels(1)
            wf.setsampwidth(2)
            wf.setframerate(fs)
            wf.writeframes(y.tobytes())
        buf.seek(0)
        with sr.AudioFile(buf) as source:
            recognizer.adjust_for_ambient_noise(source, duration=0.3)
            audio = recognizer.record(source)
        try:
            return recognizer.recognize_google(audio, language="ar-SA").strip().lower()
        except Exception:
            try:
                return recognizer.recognize_google(audio, language="en-US").strip().lower()
            except Exception:
                return ""
    except Exception:
        return ""



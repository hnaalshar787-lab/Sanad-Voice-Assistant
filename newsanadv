    def _show_profile(self):
        meta = SecurityLayer.get_user_meta(self.user_id)
        created = meta.get("created_at", "غير محدد")
        speak(f"حسابك مُنشأ بتاريخ {created[:10] if created != 'غير محدد' else created}.")
        self.status.update(f"📅 أُنشئ الحساب: {created[:10]}", C["info"])

    # ── تدفق الدفع الذكي ────────────────────────────────
    def _payment_flow(self):
        def task():
            speak("لمن تريد إرسال المبلغ؟ قل الاسم الآن.", wait=True)
            self.status.update("🎙 اذكر اسم المستفيد", C["gold"])
            self.wave.start()
            rec = sd.rec(int(self.DUR * self.FS), samplerate=self.FS, channels=1)
            sd.wait(); self.wave.stop()
            target = transcribe_audio(rec, self.FS)

            if not target:
                speak("لم أسمع الاسم. تم إلغاء العملية. حاول مجدداً.")
                self.status.update("❌ تم الإلغاء", C["danger"])
                return

            if target in self.beneficiaries:
                self._proceed_payment(target)
            else:
                speak(f"لم أجد {target} في قائمتك. هل تريد إضافته؟ قل نعم أو لا.", wait=True)
                self.status.update(f"❓ إضافة {target}؟", C["info"])
                self.wave.start()
                rec2 = sd.rec(int(4 * self.FS), samplerate=self.FS, channels=1)
                sd.wait(); self.wave.stop()
                ans = transcribe_audio(rec2, self.FS)
                if any(w in ans for w in ["نعم", "yes", "أضف", "اوكي", "تمام", "موافق"]):
                    self._add_beneficiary(target)
                    self._proceed_payment(target)
                else:
                    speak("تم إلغاء عملية الدفع.")
                    self.status.update("تم الإلغاء", C["white_40"])

        threading.Thread(target=task, daemon=True).start()

    def _proceed_payment(self, name: str):
        speak(f"كم المبلغ الذي تريد إرساله لـ {name}؟ قله الآن.", wait=True)
        self.status.update(f"💰 حدد المبلغ لـ {name}", C["gold"])
        self.wave.start()
        rec_amt = sd.rec(int(self.DUR * self.FS), samplerate=self.FS, channels=1)
        sd.wait(); self.wave.stop()
        amount = transcribe_audio(rec_amt, self.FS) or "المبلغ المذكور"

        speak(f"لتأكيد تحويل {amount} لـ {name}، قل كلمتك السرية الآن.", wait=True)
        self.status.update("🔐 أكّد بصمة صوتك", C["danger"])
        self.wave.start()
        rec_auth = sd.rec(int(self.DUR * self.FS), samplerate=self.FS, channels=1)
        sd.wait(); self.wave.stop()

        word_now    = transcribe_audio(rec_auth, self.FS)
        fp_now      = extract_fingerprint(rec_auth, self.FS)
        stored_hash = SecurityLayer.get_word_hash(self.user_id)
        word_ok     = SecurityLayer.verify_spoken_word(word_now, stored_hash)
        stored_fp   = SecurityLayer.load_fingerprint(self.user_id, word_now)
        sim         = voice_similarity(fp_now, stored_fp) if stored_fp is not None else 0.0

        if word_ok and sim > SecurityLayer.PAYMENT_THRESHOLD:
            speak(f"تم التحقق. جارٍ تحويل {amount} إلى {name}. بالتوفيق.")
            self.status.update(f"✅ تم التحويل لـ {name}", C["success"])
        else:
            speak("عذراً. كلمة السر أو بصمة الصوت غير مطابقة. تم إلغاء العملية.")
            self.status.update("❌ فشل التحقق الأمني", C["danger"])

    def _add_beneficiary(self, name: str):
        self.beneficiaries.append(name)
        self.after(0, lambda: self._render_beneficiary(name))

    def _render_beneficiary(self, name: str):
        if hasattr(self, '_empty_lbl') and self._empty_lbl.winfo_exists():
            self._empty_lbl.destroy()
        row = ctk.CTkFrame(self.scroll, fg_color=C["card"],
                           corner_radius=10, border_color=C["card_border"],
                           border_width=1)
        row.pack(fill="x", pady=3, padx=4)
        ctk.CTkLabel(row, text="👤", font=("Helvetica", 18)).pack(side="right", padx=12, pady=8)
        ctk.CTkLabel(row, text=name, font=("Helvetica", 15),
                     text_color=C["white"]).pack(side="right", pady=8)

    def _logout(self):
        speak("إلى اللقاء. تصبح على خير.")
        time.sleep(0.6)
        self.on_logout()



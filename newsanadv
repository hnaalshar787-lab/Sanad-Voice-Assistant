class SanadApp(ctk.CTk):
    def __init__(self):
        super().__init__()
        self.title("سَنَد v8.0 — نظام الدفع الذكي الصوتي")
        self.geometry("410x730")
        self.resizable(False, False)
        self.configure(fg_color=C["bg"])

        self.update_idletasks()
        sw = self.winfo_screenwidth()
        sh = self.winfo_screenheight()
        x  = (sw - 410) // 2
        y  = (sh - 730) // 2
        self.geometry(f"410x730+{x}+{y}")

        self.bind("<Key-1>", lambda e: self._show_register())
        self.bind("<Key-2>", lambda e: self._show_login())

        self._show_home()

    def _clear(self):
        for w in self.winfo_children():
            w.destroy()

    def _show_home(self):
        self._clear()
        HomeScreen(self, on_login=self._show_login, on_register=self._show_register)

    def _show_register(self):
        self._clear()
        RegisterScreen(self, on_done=self._show_home, on_back=self._show_home)

    def _show_login(self):
        self._clear()
        LoginScreen(self, on_success=self._on_login_success, on_back=self._show_home)

    def _on_login_success(self, uid, word):
        self._clear()
        DashboardScreen(self, uid, word, on_logout=self._show_home)


if __name__ == "__main__":

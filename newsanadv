        self.after(600, lambda: speak(
            "شاشة إنشاء حساب جديد. "
            "ستقوم بنطق كلمتك السرية ثلاث مرات لتسجيل بصمتك الصوتية. "
            "اختر كلمة سهلة تتذكرها، مثل اسمك أو اسم أحد أبنائك. "
            "اضغط على زر ابدأ التسجيل للبدء."
        ))

    def _build(self):
        header = ctk.CTkFrame(self, fg_color=C["surface"], height=56, corner_radius=0)
        header.pack(fill="x")
        ctk.CTkButton(header, text="→", width=44, height=36,
                      fg_color="transparent", text_color=C["gold"],
                      font=("Helvetica", 20),
                      command=lambda: [speak("العودة للقائمة الرئيسية."), self.on_back()]
                      ).pack(side="left", padx=10)
        ctk.CTkLabel(header, text="إنشاء حساب جديد",
                     font=("Helvetica", 17, "bold"),
                     text_color=C["gold"]).pack(side="right", padx=20)

        SeparatorLine(self).pack(fill="x")

        self.steps = StepsIndicator(self)
        self.steps.pack(pady=18)
        self.steps.set_step(0)

        # تعليمات واضحة للمستخدم
        info_card = ctk.CTkFrame(self, fg_color=C["card"], corner_radius=14,
                                  border_color=C["card_border"], border_width=1)
        info_card.pack(fill="x", padx=30, pady=(0, 8))
        ctk.CTkLabel(info_card,
                     text="اختر كلمة سرية وانطقها 3 مرات\nمثال: اسمك، أو اسم أحد أبنائك",
                     font=("Helvetica", 13),
                     text_color=C["white_70"],
                     justify="center").pack(padx=16, pady=12)

        self.status = StatusBadge(self, text="سنبدأ بتسجيل كلمتك السرية")
        self.status.pack(padx=30, fill="x", pady=(0, 8))

        self.wave = VoiceWaveCanvas(self, height=65)
        self.wave.pack(fill="x", padx=30, pady=8)

        self.attempt_lbl = ctk.CTkLabel(self, text="",
                                        font=("Helvetica", 13),
                                        text_color=C["white_40"])
        self.attempt_lbl.pack(pady=4)

        self.btn = GoldButton(self, text="🎤  ابدأ التسجيل", command=self._start)
        self.btn.pack(fill="x", padx=30, pady=18)

    def _start(self):
        self.btn.configure(state="disabled")
        threading.Thread(target=self._flow, daemon=True).start()

    def _flow(self):
        # ── الخطوة الوحيدة: الكلمة السرية (3 محاولات) ──
        self.after(0, lambda: self.steps.set_step(0))
        speak(
            "سأطلب منك نطق كلمتك السرية ثلاث مرات "
            "لأحفظ بصمة صوتك بدقة عالية.",
            wait=True
        )
        time.sleep(0.4)

        for i in range(self.NUM_ATTEMPTS):
            self.after(0, lambda c=i+1, t=self.NUM_ATTEMPTS: self.attempt_lbl.configure(
                text=f"المحاولة {c} من {t}", text_color=C["gold"]))

            if i == 0:
                speak("قل كلمتك السرية الآن.", wait=True)
            else:
                speak(f"المحاولة {i+1}. قل كلمتك السرية مرة أخرى.", wait=True)

            time.sleep(0.3)
            self._set_status(f"🎤 استمع... المحاولة {i+1} من {self.NUM_ATTEMPTS}", C["info"])
            self.wave.start()
            rec = sd.rec(int(self.DUR * self.FS), samplerate=self.FS, channels=1)
            sd.wait()
            self.wave.stop()

            fp   = extract_fingerprint(rec, self.FS)
            word = transcribe_audio(rec, self.FS)
            self._recordings.append(fp)
            self._words.append(word)

            self._set_status(f"✔ تم تسجيل المحاولة {i+1}", C["success"])

            if i < self.NUM_ATTEMPTS - 1:
                speak("ممتاز.", wait=True)
            else:
                speak("أحسنت! اكتملت جميع المحاولات.", wait=True)

            time.sleep(0.3)

        # ── الحفظ ────────────────────────────────────────
        self.after(0, lambda: self.steps.set_step(1))
        self._set_status("💾 جارٍ حفظ بصمتك الصوتية بأمان...", C["warning"])
        speak("جارٍ حفظ بصمة صوتك وكلمة سرك بأمان.", wait=True)

        # استخراج الكلمة الأكثر تكراراً كمرجع
        word_final = max(set(self._words), key=self._words.count) if self._words else "unknown"
        fp_agg = aggregate_fingerprints(self._recordings)

        # حفظ: hash الكلمة + البصمة المشفّرة
        SecurityLayer.store_word_hash(self._user_id, SecurityLayer.hash_spoken_word(word_final))
        SecurityLayer.save_fingerprint(fp_agg, self._user_id, word_final)
        SecurityLayer.save_user_meta(self._user_id, {
            "created_at": datetime.now().isoformat(),
            "original_word": word_final,
            # ملاحظة: لا يوجد رقم جوال في هذه النسخة
        })

        self._set_status("✅ تم إنشاء حسابك بنجاح!", C["success"])
        self.after(0, lambda: self.attempt_lbl.configure(
            text="كلمتك السرية وبصمتك محفوظتان بأمان ✔",
            text_color=C["success"]))
        speak(
            "تم إنشاء حسابك بنجاح. "
            "كلمتك السرية وبصمتك الصوتية هما وسيلتا التحقق عند الدخول. "
            "يمكنك الآن تسجيل الدخول بصوتك في أي وقت.",
            wait=True
        )
        time.sleep(1.2)
        self.after(0, self.on_done)

    def _set_status(self, text, color=None):
        self.after(0, lambda: self.status.update(text, color))


